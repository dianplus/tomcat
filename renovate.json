{
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^9/Dockerfile\\.renovate$"
      ],
      "matchStrings": [
        "^FROM\\s+(?<depName>tomcat):(?<currentValue>9\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^10/Dockerfile\\.renovate$"
      ],
      "matchStrings": [
        "^FROM\\s+(?<depName>tomcat):(?<currentValue>10\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "tomcat"
      ],
      "matchFileNames": [
        "9/Dockerfile.renovate"
      ],
      "allowedVersions": "/^9\\./"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "tomcat"
      ],
      "matchFileNames": [
        "10/Dockerfile.renovate"
      ],
      "allowedVersions": "/^10\\./"
    }
  ],
  "ignorePaths": [
    "9/**/Dockerfile-*",
    "9/**/Dockerfile",
    "10/**/Dockerfile-*",
    "10/**/Dockerfile"
  ]
}
